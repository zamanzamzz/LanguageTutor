        { "id": "l1_u3_p11", "english": "How many?", "bengali": "Koita?", "script": "কয়টা?", "prompt": { "english": "Ask: How many?", "bengali": "Proshno", "script": "প্রশ্ন" }, "culturalNote": "Used when counting items." }
