        { "id": "l1_u5_p6", "english": "With sugar", "bengali": "Chini diye", "script": "চিনি দিয়ে", "prompt": { "english": "Say: With sugar", "bengali": "Chini", "script": "চিনি" } },
        { "id": "l1_u5_p7", "english": "Without sugar", "bengali": "Chini chara", "script": "চিনি ছাড়া", "prompt": { "english": "Say: Without sugar", "bengali": "Chini", "script": "চিনি" } },
