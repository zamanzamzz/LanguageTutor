{
  "id": "level_1",
  "title": "Level 1: Foundation",
  "description": "Essential survival skills, greetings, and basic sentence structures.",
  "units": [
    {
      "id": "l1_u1",
      "title": "Greetings & Basics",
      "phrases": [
        { "id": "l1_u1_p1", "english": "Hello (Universal)", "bengali": "Assalamu Alaikum", "script": "আসসালামু আলাইকুম", "prompt": { "english": "Say hello politely", "bengali": "Shombhashon", "script": "সম্ভাষণ" }, "culturalNote": "Universal polite greeting." },
        { "id": "l1_u1_p2", "english": "How are you? (Formal)", "bengali": "Kemon achen?", "script": "কেমন আছেন?", "prompt": { "english": "Ask an elder: How are you?", "bengali": "Apni kemon achen?", "script": "আপনি কেমন আছেন?" }, "isFormal": true },
        { "id": "l1_u1_p3", "english": "How are you? (Informal)", "bengali": "Kemon acho?", "script": "কেমন আছো?", "prompt": { "english": "Ask a friend: How are you?", "bengali": "Tumi kemon acho?", "script": "তুমি কেমন আছো?" }, "isFormal": false },
        { "id": "l1_u1_p4", "english": "I am fine", "bengali": "Bhalo achi", "script": "ভালো আছি", "prompt": { "english": "Reply: I am fine", "bengali": "Kemon achen?", "script": "কেমন আছেন?" } },
        { "id": "l1_u1_p5", "english": "Thank you", "bengali": "Dhonnobad", "script": "ধন্যবাদ", "prompt": { "english": "Say: Thank you", "bengali": "Kritoggota", "script": "কৃতজ্ঞতা" } },
        { "id": "l1_u1_p6", "english": "Yes (Polite)", "bengali": "Ji", "script": "জি", "prompt": { "english": "Say: Yes (Polite)", "bengali": "Hae / Na?", "script": "হ্যাঁ / না?" } },
        { "id": "l1_u1_p7", "english": "No", "bengali": "Na", "script": "না", "prompt": { "english": "Say: No", "bengali": "Hae / Na?", "script": "হ্যাঁ / না?" } },
        { "id": "l1_u1_p8", "english": "Excuse me / Sorry", "bengali": "Maaf korben", "script": "মাফ করবেন", "prompt": { "english": "Apologize / Get attention", "bengali": "Khoma chan", "script": "ক্ষমা চান" }, "literal": "Please forgive me" },
        { "id": "l1_u1_p9", "english": "See you again", "bengali": "Abar dekha hobe", "script": "আবার দেখা হবে", "prompt": { "english": "Say: See you again", "bengali": "Biday", "script": "বিদায়" }, "words": [
          { "id": "l1_u1_p9_w1", "bengali": "Abar", "script": "আবার" },
          { "id": "l1_u1_p9_w2", "bengali": "dekha", "script": "দেখা" },
          { "id": "l1_u1_p9_w3", "bengali": "hobe", "script": "হবে" }
        ]},
        { "id": "l1_u1_p10", "english": "Goodbye", "bengali": "Khoda Hafez", "script": "খোদা হাফেজ", "prompt": { "english": "Say: Goodbye", "bengali": "Biday", "script": "বিদায়" }, "culturalNote": "Commonly used in Bangladesh when leaving." }
      ]
    },
    {
      "id": "l1_u2",
      "title": "Introductions",
      "phrases": [
        { "id": "l1_u2_p1", "english": "My name is...", "bengali": "Amar naam...", "script": "আমার নাম...", "prompt": { "english": "Say: My name is...", "bengali": "Apnar naam ki?", "script": "আপনার নাম কি?" } },
        { "id": "l1_u2_p2", "english": "What is your name? (Formal)", "bengali": "Apnar naam ki?", "script": "আপনার নাম কি?", "prompt": { "english": "Ask: What is your name? (Formal)", "bengali": "Porichoy", "script": "পরিচয়" }, "isFormal": true },
        { "id": "l1_u2_p3", "english": "I am from...", "bengali": "Aami ... theke eshechi", "script": "আমি ... থেকে এসেছি", "prompt": { "english": "Say: I am from...", "bengali": "Apni kotha theke eshechen?", "script": "আপনি কোথা থেকে এসেছেন?" } },
        { "id": "l1_u2_p4", "english": "Nice to meet you", "bengali": "Apnar shathe porichoy hoye bhalo laglo", "script": "আপনার সাথে পরিচয় হয়ে ভালো লাগলো", "prompt": { "english": "Say: Nice to meet you", "bengali": "Porichoy", "script": "পরিচয়" } },
        { "id": "l1_u2_p5", "english": "What is your name? (Informal)", "bengali": "Tomar naam ki?", "script": "তোমার নাম কি?", "prompt": { "english": "Ask a friend: What is your name?", "bengali": "Porichoy", "script": "পরিচয়" }, "isFormal": false },
        { "id": "l1_u2_p6", "english": "What do you do? (Formal)", "bengali": "Apni ki koren?", "script": "আপনি কি করেন?", "prompt": { "english": "Ask: What do you do?", "bengali": "Pesha", "script": "পেশা" }, "isFormal": true },
        { "id": "l1_u2_p7", "english": "I am a student", "bengali": "Aami ekjon chhatro", "script": "আমি একজন ছাত্র", "prompt": { "english": "Say: I am a student", "bengali": "Apni ki koren?", "script": "আপনি কি করেন?" } },
        { "id": "l1_u2_p8", "english": "Where do you live? (Formal)", "bengali": "Apni kothay thaken?", "script": "আপনি কোথায় থাকেন?", "prompt": { "english": "Ask: Where do you live?", "bengali": "Thikana", "script": "ঠিকানা" }, "isFormal": true },
        { "id": "l1_u2_p9", "english": "I live in [City]", "bengali": "Aami [City]-te thaki", "script": "আমি [City]-তে থাকি", "prompt": { "english": "Say: I live in [City]", "bengali": "Apni kothay thaken?", "script": "আপনি কোথায় থাকেন?" } },
        { "id": "l1_u2_p10", "english": "Who is he/she?", "bengali": "Uni ke?", "script": "উনি কে?", "prompt": { "english": "Ask: Who is he/she?", "bengali": "Porichoy", "script": "পরিচয়" }, "culturalNote": "Using 'Uni' is the respectful way to refer to someone older or a stranger." }
      ]
    },
    {
