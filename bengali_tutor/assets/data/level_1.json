        { "id": "l1_u3_p6", "english": "Six", "bengali": "Choy", "script": "ছয়", "prompt": { "english": "Number: 6", "bengali": "Shongkha", "script": "সংখ্যা" } },
        { "id": "l1_u3_p7", "english": "Seven", "bengali": "Saat", "script": "সাত", "prompt": { "english": "Number: 7", "bengali": "Shongkha", "script": "সংখ্যা" } },
        { "id": "l1_u3_p8", "english": "Eight", "bengali": "Aat", "script": "আট", "prompt": { "english": "Number: 8", "bengali": "Shongkha", "script": "সংখ্যা" } },
