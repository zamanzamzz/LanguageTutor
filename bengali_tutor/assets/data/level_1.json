    {
      "id": "l1_u4",
      "title": "Essential Shopping",
      "phrases": [
        { "id": "l1_u4_p1", "english": "How much is this?", "bengali": "Eitar dam koto?", "script": "এটার দাম কত?", "prompt": { "english": "Ask: How much is this?", "bengali": "Dam koto?", "script": "দাম কত?" } },
        { "id": "l1_u4_p2", "english": "I want this", "bengali": "Aami eta chai", "script": "আমি এটা চাই", "prompt": { "english": "Say: I want this", "bengali": "Kenakata", "script": "কেনাকাটা" } },
        { "id": "l1_u4_p3", "english": "I don't want this", "bengali": "Aami eta chai na", "script": "আমি এটা চাই না", "prompt": { "english": "Say: I don't want this", "bengali": "Kenakata", "script": "কেনাকাটা" } },
        { "id": "l1_u4_p4", "english": "It is very expensive", "bengali": "Onek dam", "script": "অনেক দাম", "prompt": { "english": "Complain: It is very expensive", "bengali": "Dam koto?", "script": "দাম কত?" } },
        { "id": "l1_u4_p5", "english": "Can you lower the price?", "bengali": "Ektu kom rakhen?", "script": "একটু কম রাখেন?", "prompt": { "english": "Ask to lower the price", "bengali": "Dam koman", "script": "দাম কমান" }, "culturalNote": "Common way to start bargaining." },
        { "id": "l1_u4_p6", "english": "Do you have a bag?", "bengali": "Bag ache?", "script": "ব্যাগ আছে?", "prompt": { "english": "Ask: Do you have a bag?", "bengali": "Bag lagbe", "script": "ব্যাগ লাগবে" } },
        { "id": "l1_u4_p7", "english": "I like this color", "bengali": "Amar ei rong-ta pochondo", "script": "আমার এই রঙটা পছন্দ", "prompt": { "english": "Say: I like this color", "bengali": "Pochondo", "script": "পছন্দ" } },
        { "id": "l1_u4_p8", "english": "Where is the market?", "bengali": "Bazar kothay?", "script": "বাজার কোথায়?", "prompt": { "english": "Ask: Where is the market?", "bengali": "Thikana", "script": "ঠিকানা" } },
        { "id": "l1_u4_p9", "english": "Give me this one", "bengali": "Ei-ta den", "script": "এইটা দেন", "prompt": { "english": "Say: Give me this one", "bengali": "Kenakata", "script": "কেনাকাটা" } },
        { "id": "l1_u4_p10", "english": "Keep the change", "bengali": "Baki-ta rakhen", "script": "বাকিটা রাখেন", "prompt": { "english": "Say: Keep the change", "bengali": "Bill", "script": "বিল" } }
      ]
    },
    {
